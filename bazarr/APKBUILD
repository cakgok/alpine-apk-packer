pkgname=bazarr
pkgver=1.5.6
pkgrel=2
pkgdesc="Bazarr – companion app for Sonarr/Radarr that fetches subtitles"
url="https://bazarr.media"
arch="x86_64"
license="GPL-3.0-or-later"

depends="
    7zip
    ffmpeg
    mediainfo
    python3
    py3-wheel
    py3-lxml
    py3-numpy
    py3-gevent
    py3-cryptography
    py3-setuptools
    py3-psycopg2
    py3-pillow
    "

makedepends="
    py3-pip
    gcc
    python3-dev
    musl-dev
    unzip
    "

pkgusers="bazarr"
pkggroups="bazarr"
subpackages="$pkgname-openrc::x86_64"
install="$pkgname.pre-install"

source="$pkgname-$pkgver.zip::https://github.com/morpheus65535/bazarr/releases/download/v$pkgver/bazarr.zip
  webrtcvad-wheels-2.0.14.tar.gz::https://github.com/daanzu/py-webrtcvad-wheels/archive/refs/tags/v2.0.14.tar.gz
  bazarr.initd
  bazarr.confd
  bazarr.wrapper
"

prepare() {
    # Isolate the unpacked contents
    mkdir -p "$srcdir/unpacked"
    unzip -q "$srcdir/$pkgname-$pkgver.zip" -d "$srcdir/unpacked"
    # Find the actual root of the source code
    local _app_root="$srcdir/unpacked"
    cd "$_app_root"
    # Check if there's a nested zip
    set -- *
    if [ $# -eq 1 ] && [ -d "$1" ]; then
        _app_root="$_app_root/$1"
    fi
    # Create clean folder for the app src
    mkdir -p "$srcdir/app-source"
    # Copy only the app files into the dir
    cp -a "$_app_root/." "$srcdir/app-source/"
    # Clean up
    cd "$srcdir"
    rm -rf "$srcdir/unpacked"
}

build() {
    # PyPI does not publish a musllinux wheel for every edge Python ABI.
    # Build WebRTC VAD from source so the Bazarr APK remains self-contained and
    # tracks the target Python ABI.
    python3 -m pip wheel \
        --no-cache-dir --no-deps --no-build-isolation \
        --wheel-dir="$srcdir/wheelhouse" \
        "$srcdir/py-webrtcvad-wheels-2.0.14"
}

check() {
    # Bazarr bundles this dependency. Import it explicitly so removed Python
    # APIs such as pkg_resources fail the package build instead of startup.
    if grep -Rq 'from pkg_resources import' \
        "$srcdir/app-source/libs/python_anticaptcha"; then
        error "bundled python_anticaptcha still imports removed pkg_resources APIs"
        return 1
    fi

    PYTHONPATH="$srcdir/app-source/libs" \
        python3 -c 'import python_anticaptcha'
}

package() {
    install -dm755 "$pkgdir/usr/lib/bazarr"
    install -dm755 "$pkgdir/usr/bin"
    install -dm755 "$pkgdir/var/lib/bazarr"

    cp -a "$srcdir/app-source"/. "$pkgdir/usr/lib/bazarr/"

    pip install \
        --break-system-packages \
        --no-deps --no-cache-dir --no-index \
        --find-links="$srcdir/wheelhouse" \
        --root="$pkgdir" --prefix=/usr \
        "webrtcvad-wheels>=2.0.14"

    PYTHONPATH="$pkgdir/usr/lib/python$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')/site-packages" \
        python3 -c 'import webrtcvad'

    install -Dm755 "$srcdir"/$pkgname.wrapper "$pkgdir"/usr/bin/$pkgname
    install -Dm755 "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
    install -Dm644 "$srcdir"/$pkgname.confd "$pkgdir"/etc/conf.d/$pkgname
}

